# FHIR Data Layer Mode: static | cloud | local
FHIR_MODE=static

# Medplum Cloud Credentials (required for cloud mode)
MEDPLUM_CLIENT_ID=your_client_id_here
MEDPLUM_CLIENT_SECRET=your_client_secret_here
MEDPLUM_BASE_URL=https://api.medplum.com/fhir/R4
MEDPLUM_TOKEN_URL=https://api.medplum.com/oauth2/token

# Local Docker (optional, only if FHIR_MODE=local)
FHIR_LOCAL_URL=http://localhost:8080

# LLM (optional, for agent reasoning)
ANTHROPIC_API_KEY=

# Frontend
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
